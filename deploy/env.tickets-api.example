# ═══════════════════════════════════════════════════
#  zentto-tickets API — Producción
#  Ubicación en servidor: /opt/zentto/.env.tickets-api
# ═══════════════════════════════════════════════════

PORT=4700
NODE_ENV=production

# JWT — DEBE ser el mismo secret que zentto-auth
JWT_SECRET=<copiar_de_zentto_auth>

# PostgreSQL (host PG via Docker gateway)
PG_HOST=172.19.0.1
PG_PORT=5432
PG_DATABASE=zentto_tickets
PG_USER=zentto_app
PG_PASSWORD=<password_zentto_app>

# Redis
REDIS_URL=redis://172.19.0.1:6379

# zentto-auth (dentro de la red Docker)
AUTH_SERVICE_URL=http://zentto-auth:4600

# zentto-notify
NOTIFY_URL=http://zentto-notify:5000
NOTIFY_API_KEY=zntfy_<generar_en_notify_dashboard>

# WebSocket
WS_PORT=4701
