# ═══════════════════════════════════════════════════
#  zentto-tickets Frontend — Producción
#  Ubicación en servidor: /opt/zentto/.env.tickets-frontend
# ═══════════════════════════════════════════════════

NODE_ENV=production

# NextAuth
AUTH_SECRET=<secreto_aleatorio_32_chars>
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://tickets.zentto.net

# zentto-auth (server-side, dentro de red Docker)
AUTH_SERVICE_URL=http://zentto-auth:4600

# URLs públicas (baked at build time, pero override runtime si es necesario)
NEXT_PUBLIC_API_URL=https://tickets-api.zentto.net
NEXT_PUBLIC_AUTH_URL=https://auth.zentto.net
