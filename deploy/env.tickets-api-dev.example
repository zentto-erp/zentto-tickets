PORT=4700
NODE_ENV=development

JWT_SECRET=<copiar_de_zentto_auth>

PG_HOST=172.19.0.1
PG_PORT=5432
PG_DATABASE=zentto_tickets_dev
PG_USER=zentto_app
PG_PASSWORD=<password_zentto_app>

REDIS_URL=redis://172.19.0.1:6379

AUTH_SERVICE_URL=http://zentto-auth-dev:4600

