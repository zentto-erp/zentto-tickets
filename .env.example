# ═══════════════════════════════════════════════════
#  Zentto Tickets — Variables de entorno
# ═══════════════════════════════════════════════════

# ── API ──
PORT=4700
NODE_ENV=development

# ── JWT (DEBE ser el MISMO secret que zentto-auth) ──
JWT_SECRET=change_me

# ── PostgreSQL ──
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=zentto_tickets
PG_USER=postgres
PG_PASSWORD=tickets123

# ── Redis (seat holds + pub/sub) ──
REDIS_URL=redis://localhost:6379

# ── Zentto Auth Microservice ──
# URL interna (docker network): http://zentto-auth:4600
# URL publica: https://auth.zentto.net
AUTH_SERVICE_URL=http://localhost:4600

# ── Zentto Notify (emails, SMS, push) ──
# URL interna: http://zentto-notify:5000
# URL publica: https://notify.zentto.net
NOTIFY_URL=https://notify.zentto.net
NOTIFY_API_KEY=zntfy_change_me

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_URL=http://localhost:4700
NEXT_PUBLIC_AUTH_URL=http://localhost:4600

# ── NextAuth ──
AUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=http://localhost:3300

# ── WebSocket ──
WS_PORT=4701
