# ── API ──
PORT=4700
NODE_ENV=development

# ── JWT (mismo secret que zentto-web API para validar tokens) ──
JWT_SECRET=change_me

# ── PostgreSQL ──
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=zentto_tickets
PG_USER=postgres
PG_PASSWORD=change_me

# ── Redis (seat holds + pub/sub) ──
REDIS_URL=redis://localhost:6379

# ── Zentto API (auth microservice) ──
ZENTTO_API_URL=http://localhost:4000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:4700
NEXT_PUBLIC_ZENTTO_API_URL=http://localhost:4000
NEXT_PUBLIC_SHELL_URL=http://localhost:3000

# ── NextAuth ──
AUTH_SECRET=change_me
BACKEND_URL=http://localhost:4700

# ── WebSocket ──
WS_PORT=4701
