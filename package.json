{
  "name": "zentto-tickets",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "api",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "npm --workspace api run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm run build:api && npm run build:frontend",
    "build:api": "npm --workspace api run build",
    "build:frontend": "npm --workspace frontend run build",
    "start:api": "npm --workspace api run start",
    "start:frontend": "npm --workspace frontend run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
